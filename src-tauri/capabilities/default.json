{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:webview:allow-internal-toggle-devtools",
    "opener:default",
    "fs:default",
    "fs:allow-read-dir",
    "fs:allow-read-file",
    "updater:default",
    "process:default",
    "process:allow-restart",
    "dialog:default",
    "dialog:allow-open"
  ]
}

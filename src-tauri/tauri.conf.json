  "identifier": "com.ghostproducerworld.uploader",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "GPW Uploader",
        "width": 1000,
        "height": 720,
        "minWidth": 820,
        "minHeight": 600,
        "resizable": true,
        "dragDropEnabled": true,

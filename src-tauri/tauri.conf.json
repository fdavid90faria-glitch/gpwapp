{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "GPW Uploader",
  "version": "0.1.0",
  "identifier": "com.ghostproducerworld.uploader",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "GPW Uploader",
        "width": 1000,
        "height": 720,
        "minWidth": 820,
        "minHeight": 600,
        "resizable": true,
        "dragDropEnabled": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "externalBin": ["binaries/lame"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/fdavid90faria-glitch/gpwapp/releases/latest/download/latest.json"
      ],
